# MetaApi Configuration
META_API_KEY=your_meta_api_key_here
META_API_SANDBOX=true
META_API_LOGIN=0  # 0 = auto-provision demo account

# OpenAI Configuration
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# Database
DATABASE_URL=postgresql://user:pass@localhost:5432/trading_ai
REDIS_URL=redis://localhost:6379/0

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# Risk Defaults
MAX_POSITION_SIZE_PCT=5
MAX_OPEN_TRADES=5
DEFAULT_STOP_LOSS_PIPS=50
DEFAULT_TAKE_PROFIT_PIPS=100
